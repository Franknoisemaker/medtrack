# ============================================================
# MedTrack — .gitignore raíz del monorepo
# ============================================================

# ----------------------------
# Secretos y Variables de Entorno (NUNCA subir a git)
# ----------------------------
.env
.env.*
!.env.example

# ----------------------------
# Dependencias
# ----------------------------
node_modules/
.pnpm-store/

# ----------------------------
# Build artifacts
# ----------------------------
dist/
dist-ssr/
build/
.vercel/

# ----------------------------
# Supabase local
# ----------------------------
supabase/.branches/
supabase/.temp/
**/supabase/.branches/
**/supabase/.temp/

# ----------------------------
# Logs
# ----------------------------
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ----------------------------
# Editor / OS
# ----------------------------
.DS_Store
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
Thumbs.db

# ----------------------------
# Testing / Coverage
# ----------------------------
coverage/
.nyc_output/

# ----------------------------
# BMad / Agent (no relevante para el repo de producto)
# ----------------------------
.agent/
_bmad/
_bmad-output/
